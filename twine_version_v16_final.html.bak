<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#1a1a2e">
    <title>🌌 多元宇宙概念收集者 v0.15 - 最终修复版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        body {
            font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #e0e0e0;
            line-height: 1.8;
            min-height: 100vh;
            padding: 10px;
            overflow-x: hidden;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
        }
        
        header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        }
        
        h1 {
            font-size: clamp(1.5em, 5vw, 2.5em);
            margin-bottom: 10px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .subtitle {
            color: #888;
            font-size: clamp(0.9em, 3vw, 1.1em);
        }
        
        .scene {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .scene-title {
            font-size: clamp(1.3em, 4vw, 1.8em);
            margin-bottom: 15px;
            color: #667eea;
        }
        
        .scene-text {
            font-size: clamp(1em, 3.5vw, 1.1em);
            margin-bottom: 20px;
            white-space: pre-wrap;
            line-height: 1.6;
        }
        
        .choices {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .choice-btn {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(118, 75, 162, 0.2));
            border: 2px solid rgba(102, 126, 234, 0.5);
            color: #e0e0e0;
            padding: clamp(12px, 3vw, 15px) clamp(15px, 4vw, 25px);
            border-radius: 10px;
            font-size: clamp(1em, 3.5vw, 1.1em);
            cursor: pointer;
            transition: all 0.3s;
            text-align: left;
            min-height: 44px;
            touch-action: manipulation;
        }
        
        .choice-btn:hover {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.4), rgba(118, 75, 162, 0.4));
            border-color: #667eea;
            transform: translateX(5px);
        }
        
        .choice-btn:active {
            transform: scale(0.98);
        }
        
        .status-bar {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 10px;
        }
        
        .status-item {
            text-align: center;
        }
        
        .status-label {
            font-size: clamp(0.8em, 2.5vw, 0.9em);
            color: #888;
            margin-bottom: 5px;
        }
        
        .status-value {
            font-size: clamp(1.2em, 4vw, 1.5em);
            font-weight: bold;
            color: #667eea;
        }
        
        .concept-collected {
            background: linear-gradient(135deg, rgba(67, 233, 123, 0.2), rgba(56, 249, 215, 0.2));
            border: 2px solid rgba(67, 233, 123, 0.5);
            border-radius: 10px;
            padding: 15px 25px;
            text-align: center;
            margin: 20px 0;
            animation: glow 2s ease-in-out infinite;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 1000;
            min-width: 300px;
        }
        
        @keyframes glow {
            0%, 100% { box-shadow: 0 0 20px rgba(67, 233, 123, 0.5); }
            50% { box-shadow: 0 0 40px rgba(67, 233, 123, 0.8); }
        }
        
        .concept-name {
            font-size: clamp(1.2em, 4vw, 1.5em);
            font-weight: bold;
            color: #43e97b;
        }
        
        .hidden {
            display: none !important;
        }
        
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .save-system {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .save-system-title {
            font-size: clamp(1.2em, 4vw, 1.4em);
            color: #667eea;
            margin-bottom: 15px;
            text-align: center;
        }
        
        .save-slots {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 10px;
            margin-bottom: 15px;
        }
        
        .save-slot {
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid rgba(102, 126, 234, 0.3);
            border-radius: 10px;
            padding: 12px;
            cursor: pointer;
            transition: all 0.3s;
            min-height: 44px;
            touch-action: manipulation;
        }
        
        .save-slot:hover {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.1);
            transform: translateY(-3px);
        }
        
        .save-slot.has-data {
            border-color: rgba(67, 233, 123, 0.5);
        }
        
        .save-slot.has-data:hover {
            border-color: #43e97b;
            background: rgba(67, 233, 123, 0.1);
        }
        
        .save-slot-info {
            font-size: clamp(0.8em, 2.5vw, 0.9em);
            color: #888;
            margin-top: 8px;
        }
        
        .save-slot-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
        }
        
        .save-btn, .load-btn, .delete-btn {
            padding: clamp(8px, 2.5vw, 10px) clamp(12px, 3vw, 16px);
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: clamp(0.85em, 2.5vw, 0.9em);
            transition: all 0.3s;
            min-height: 44px;
            touch-action: manipulation;
        }
        
        .save-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }
        
        .save-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }
        
        .load-btn {
            background: linear-gradient(135deg, #43e97b, #38f9d7);
            color: #1a1a2e;
        }
        
        .load-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(67, 233, 123, 0.4);
        }
        
        .delete-btn {
            background: rgba(255, 100, 100, 0.3);
            color: #ff6464;
            border: 1px solid rgba(255, 100, 100, 0.5);
        }
        
        .delete-btn:hover {
            background: rgba(255, 100, 100, 0.5);
            transform: scale(1.05);
        }
        
        .save-message {
            text-align: center;
            padding: 10px;
            margin-top: 15px;
            border-radius: 8px;
            font-weight: bold;
        }
        
        .save-success {
            background: rgba(67, 233, 123, 0.2);
            color: #43e97b;
        }
        
        .save-error {
            background: rgba(255, 100, 100, 0.2);
            color: #ff6464;
        }
        
        .menu-bar {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }
        
        .menu-btn {
            background: rgba(102, 126, 234, 0.2);
            border: 2px solid rgba(102, 126, 234, 0.5);
            color: #e0e0e0;
            padding: clamp(10px, 2.5vw, 12px) clamp(15px, 3vw, 20px);
            border-radius: 8px;
            cursor: pointer;
            font-size: clamp(0.9em, 2.5vw, 1em);
            transition: all 0.3s;
            min-height: 44px;
            touch-action: manipulation;
        }
        
        .menu-btn:hover {
            background: rgba(102, 126, 234, 0.4);
            border-color: #667eea;
            transform: translateY(-2px);
        }
        
        .menu-btn:active {
            transform: scale(0.98);
        }
        
        .concept-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            border: 2px solid rgba(102, 126, 234, 0.3);
            transition: all 0.3s;
        }
        
        .concept-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.3);
        }
        
        .concept-card.common { border-color: #4a9eff; }
        .concept-card.rare { border-color: #a335ee; }
        .concept-card.epic { border-color: #ff8000; }
        .concept-card.legendary { border-color: #ffcc00; }
        
        .concept-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .concept-card-title {
            font-size: clamp(1.1em, 3.5vw, 1.2em);
            font-weight: bold;
            color: #667eea;
        }
        
        .rarity-badge {
            padding: 3px 10px;
            border-radius: 15px;
            font-size: clamp(0.75em, 2.5vw, 0.8em);
            font-weight: bold;
        }
        
        .rarity-badge.common { background: #4a9eff; color: white; }
        .rarity-badge.rare { background: #a335ee; color: white; }
        .rarity-badge.epic { background: #ff8000; color: white; }
        .rarity-badge.legendary { background: #ffcc00; color: black; }
        
        .concept-card-body {
            font-size: clamp(0.9em, 3vw, 0.95em);
            color: #ccc;
        }
        
        .concept-card-science {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            font-size: clamp(0.85em, 2.5vw, 0.9em);
            color: #888;
        }
        
        .locked-concept {
            opacity: 0.5;
            filter: blur(2px);
            pointer-events: none;
        }
        
        .achievement-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            border: 2px solid rgba(102, 126, 234, 0.3);
            transition: all 0.3s;
            min-width: 200px;
        }
        
        .achievement-card.unlocked {
            border-color: #f0a500;
            background: rgba(240, 165, 0, 0.1);
        }
        
        .achievement-card.locked {
            opacity: 0.5;
            filter: grayscale(100%);
        }
        
        .achievement-icon {
            font-size: clamp(2.5em, 6vw, 3em);
            margin-bottom: 10px;
        }
        
        .achievement-name {
            font-size: clamp(1em, 3vw, 1.1em);
            font-weight: bold;
            color: #f0a500;
            margin-bottom: 5px;
        }
        
        .achievement-desc {
            font-size: clamp(0.85em, 2.5vw, 0.9em);
            color: #888;
        }
        
        footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            color: #666;
            font-size: clamp(0.85em, 2.5vw, 0.9em);
        }
        
        /* 结局样式 */
        .ending-scene {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
            border: 3px solid #667eea;
        }
        
        .ending-title {
            font-size: clamp(1.8em, 5vw, 2.5em);
            text-align: center;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #667eea, #764ba2, #f0a500);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: glow 3s ease-in-out infinite;
        }
        
        .ending-text {
            font-size: clamp(1.1em, 3.5vw, 1.2em);
            line-height: 2;
            text-align: center;
            margin-bottom: 20px;
        }
        
        .stats-summary {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        
        .progress-bar {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            height: 20px;
            overflow: hidden;
            margin: 10px 0;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.5s ease;
        }
        

        /* 返回主宇宙按钮 */
        .return-btn {
            background: linear-gradient(135deg, rgba(255, 100, 100, 0.3), rgba(255, 150, 150, 0.3));
            border: 2px solid rgba(255, 100, 100, 0.6);
            color: #ff6464;
            padding: clamp(10px, 2.5vw, 12px) clamp(15px, 3vw, 20px);
            border-radius: 8px;
            cursor: pointer;
            font-size: clamp(0.9em, 2.5vw, 1em);
            transition: all 0.3s;
            min-height: 44px;
            touch-action: manipulation;
            font-weight: bold;
        }
        
        .return-btn:hover {
            background: linear-gradient(135deg, rgba(255, 100, 100, 0.5), rgba(255, 150, 150, 0.5));
            border-color: #ff6464;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255, 100, 100, 0.4);
        }
        
        .return-btn:active {
            transform: scale(0.98);
        }
        
        /* 音乐控制面板 */
        .music-controls {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .music-btn {
            background: rgba(102, 126, 234, 0.2);
            border: 2px solid rgba(102, 126, 234, 0.5);
            color: #e0e0e0;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            transition: all 0.3s;
            min-height: 44px;
            min-width: 44px;
            touch-action: manipulation;
        }
        
        .music-btn:hover {
            background: rgba(102, 126, 234, 0.4);
            border-color: #667eea;
        }
        
        .music-btn:active {
            transform: scale(0.95);
        }
        
        .volume-control {
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            min-width: 150px;
        }
        
        .volume-slider {
            flex: 1;
            height: 8px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.1);
            outline: none;
            -webkit-appearance: none;
            appearance: none;
        }
        
        .volume-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #667eea;
            cursor: pointer;
            min-width: 44px;
            min-height: 44px;
        }
        
        .volume-slider::-moz-range-thumb {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #667eea;
            cursor: pointer;
            border: none;
        }
        
        .music-status {
            font-size: 0.9em;
            color: #888;
            min-width: 80px;
            text-align: center;
        }
        
        /* 横屏优化 */
        @media screen and (orientation: landscape) and (max-height: 500px) {
            .container {
                padding: 15px;
            }
            
            .scene {
                padding: 15px;
            }
            
            h1 {
                font-size: 1.8em;
            }
            
            .status-bar {
                grid-template-columns: repeat(4, 1fr);
            }
        }
        
        /* 小屏幕优化 */
        @media screen and (max-width: 480px) {
            body {
                padding: 5px;
            }
            
            .container {
                padding: 15px;
                border-radius: 15px;
            }
            
            .menu-bar {
                gap: 8px;
            }
            
            .menu-btn {
                flex: 1 1 calc(50% - 8px);
                text-align: center;
            }
            
            .status-bar {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .save-slots {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🌌 多元宇宙概念收集者</h1>
            <div class="subtitle">v0.15 - 最终修复版 | 104 场景 | 48 概念 | 5 大宇宙</div>
        </header>
        
        <!-- 音乐控制面板 -->
        <div class="music-controls">
            <button class="music-btn" id="music-toggle" onclick="toggleMusic()">🎵 音乐：开</button>
            <div class="volume-control">
                <span>🔊</span>
                <input type="range" class="volume-slider" id="volume-slider" min="0" max="100" value="50" onchange="setVolume(this.value)">
            </div>
            <button class="music-btn" onclick="nextTrack()">⏭️ 下一首</button>
            <div class="music-status" id="music-status">加载中...</div>
        </div>
        
        <div class="menu-bar">
            <button class="return-btn hidden" id="return-home-btn" onclick="returnToHome()">🏠 返回主宇宙</button>
            <button class="menu-btn" onclick="toggleSaveSystem()">💾 存档管理</button>
            <button class="menu-btn" onclick="toggleConcepts()">📦 概念图鉴</button>
            <button class="menu-btn" onclick="toggleAchievements()">🏆 成就系统</button>
            <button class="menu-btn" onclick="resetGame()">🔄 重新开始</button>
        </div>
        
        <div class="status-bar">
            <div class="status-item">
                <div class="status-label">🌍 当前宇宙</div>
                <div class="status-value" id="universe-display">主宇宙</div>
            </div>
            <div class="status-item">
                <div class="status-label">📦 收集概念</div>
                <div class="status-value" id="concepts-display">0</div>
            </div>
            <div class="status-item">
                <div class="status-label">⭐ 得分</div>
                <div class="status-value" id="score-display">0</div>
            </div>
            <div class="status-item">
                <div class="status-label">📖 章节</div>
                <div class="status-value" id="chapter-display">1</div>
            </div>
        </div>
        
        <div id="save-system" class="save-system hidden">
            <h2 class="save-system-title">💾 存档管理</h2>
            <div class="save-slots">
                <div class="save-slot" id="slot-1" onclick="selectSlot(1)">
                    <div><strong>存档位 1</strong></div>
                    <div class="save-slot-info" id="slot-1-info">空</div>
                </div>
                <div class="save-slot" id="slot-2" onclick="selectSlot(2)">
                    <div><strong>存档位 2</strong></div>
                    <div class="save-slot-info" id="slot-2-info">空</div>
                </div>
                <div class="save-slot" id="slot-3" onclick="selectSlot(3)">
                    <div><strong>存档位 3</strong></div>
                    <div class="save-slot-info" id="slot-3-info">空</div>
                </div>
            </div>
            <div class="save-slot-actions">
                <button class="save-btn" onclick="saveGame()">💾 保存</button>
                <button class="load-btn" onclick="loadGame()">📂 读取</button>
                <button class="delete-btn" onclick="deleteSave()">🗑️ 删除</button>
            </div>
            <div id="save-message" class="save-message hidden"></div>
        </div>
        
        <div id="concept-gallery" class="save-system hidden">
            <h2 class="save-system-title">📦 概念图鉴</h2>
            <div class="progress-bar">
                <div class="progress-fill" id="concept-progress-bar" style="width: 0%"></div>
            </div>
            <div style="text-align: center; margin-bottom: 20px;">
                收集进度：<span id="concept-progress">0/100</span>
            </div>
            <div id="concept-list"></div>
        </div>
        
        <div id="achievement-system" class="save-system hidden">
            <h2 class="save-system-title">🏆 成就系统</h2>
            <div id="achievement-list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;"></div>
        </div>
        
        <div id="game-container"></div>
        
        <footer>
            <div>🎮 多元宇宙概念收集者 v0.15 - 最终修复版</div>
            <div>© 2024 科幻游戏实验室 | 104 场景 | 48 概念 | 5 大宇宙完整体验</div>
        </footer>
    </div>
    
    <script>
        // ============ 音乐系统 ============
        const musicTracks = [
            { name: "赛博朋克", url: "https://cdn.pixabay.com/download/audio/2022/03/10/audio_c80a92896f.mp3?filename=cyberpunk-city-112247.mp3" },
            { name: "太空探索", url: "https://cdn.pixabay.com/download/audio/2022/03/24/audio_c617521644.mp3?filename=space-atmosphere-112896.mp3" },
            { name: "神秘魔法", url: "https://cdn.pixabay.com/download/audio/2022/01/18/audio_d0a13f69c2.mp3?filename=fantasy-magic-110295.mp3" },
            { name: "未来科技", url: "https://cdn.pixabay.com/download/audio/2022/03/15/audio_6389620a5d.mp3?filename=futuristic-technology-112467.mp3" },
            { name: "生命科学", url: "https://cdn.pixabay.com/download/audio/2021/11/25/audio_0f9a9f5b62.mp3?filename=ambient-science-109384.mp3" }
        ];
        
        const soundEffects = {
            collect: "https://cdn.pixabay.com/download/audio/2021/08/04/audio_06d5c5c8f7.mp3?filename=success-1-112247.mp3",
            achievement: "https://cdn.pixabay.com/download/audio/2021/08/04/audio_7f4f10f7a6.mp3?filename=achievement-1-112248.mp3",
            sceneChange: "https://cdn.pixabay.com/download/audio/2021/08/04/audio_9a2f10e8b5.mp3?filename=transition-1-112249.mp3",
            save: "https://cdn.pixabay.com/download/audio/2021/08/04/audio_8b3f10d9c4.mp3?filename=save-1-112250.mp3"
        };
        
        let currentAudio = null;
        let isMusicPlaying = true;
        let currentVolume = 0.5;
        let currentTrackIndex = 0;
        
        // 音效音频池
        const audioPool = {};
        
        function initAudio() {
            // 预加载音效
            for (const [name, url] of Object.entries(soundEffects)) {
                const audio = new Audio(url);
                audio.preload = 'auto';
                audio.volume = 0.3;
                audioPool[name] = audio;
            }
            
            // 加载第一首背景音乐
            loadTrack(0);
            updateMusicStatus();
        }
        
        function loadTrack(index) {
            if (currentAudio) {
                currentAudio.fadeOut(0.5, () => {
                    currentAudio.pause();
                    currentAudio.currentTime = 0;
                    playTrack(index);
                });
            } else {
                playTrack(index);
            }
        }
        
        function playTrack(index) {
            const track = musicTracks[index];
            currentAudio = new Audio(track.url);
            currentAudio.loop = true;
            currentAudio.volume = isMusicPlaying ? currentVolume : 0;
            currentAudio.addEventListener('canplaythrough', () => {
                if (isMusicPlaying) {
                    currentAudio.play().catch(e => console.log('Audio autoplay blocked:', e));
                }
            });
            currentAudio.load();
            currentTrackIndex = index;
            updateMusicStatus();
        }
        
        function toggleMusic() {
            isMusicPlaying = !isMusicPlaying;
            if (currentAudio) {
                if (isMusicPlaying) {
                    currentAudio.volume = currentVolume;
                    currentAudio.play().catch(e => console.log('Audio play blocked:', e));
                } else {
                    currentAudio.volume = 0;
                }
            }
            document.getElementById('music-toggle').textContent = isMusicPlaying ? '🎵 音乐：开' : '🔇 音乐：关';
        }
        
        function setVolume(value) {
            currentVolume = value / 100;
            if (currentAudio && isMusicPlaying) {
                currentAudio.volume = currentVolume;
            }
        }
        
        function nextTrack() {
            const nextIndex = (currentTrackIndex + 1) % musicTracks.length;
            loadTrack(nextIndex);
        }
        
        function updateMusicStatus() {
            const status = document.getElementById('music-status');
            if (musicTracks[currentTrackIndex]) {
                status.textContent = `🎵 ${musicTracks[currentTrackIndex].name}`;
            }
        }
        
        function playSound(name) {
            if (audioPool[name]) {
                const sound = audioPool[name].cloneNode();
                sound.volume = 0.3;
                sound.play().catch(e => console.log('Sound effect blocked:', e));
            }
        }
        
        // ============ 游戏数据 ============
        const SAVE_PREFIX = 'multiverse_save_';
