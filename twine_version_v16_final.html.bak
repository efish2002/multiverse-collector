                    { text: "🔙 返回学院", next: "magic_intro" }
                ]
            },
            
            "show_concepts_menu": {
                title: "📦 概念图鉴",
                text: () => {
                    if (gameData.concepts.length === 0) {
                        return "你还没有收集任何概念。继续探索吧！";
                    }
                    return `已收集概念：${gameData.concepts.length}/100\n\n继续探索更多宇宙，收集更多概念！`;
