【游戏进度】80%
【解锁成就】接近完美`,
                onEnter: () => {
                    gameData.achievements.push('ending_80');
                },
                choices: [
                    { text: "🔄 继续收集", next: "start" },
                    { text: "📦 查看概念图鉴", next: "show_concepts_menu" }
                ]
            },
            
            "ending_100": {
                title: "🌈 结局：完美新生",
                text: `恭喜你！你收集了全部 100 个概念，探索了所有 5 个宇宙！

主宇宙在你的努力下完全修复，并且变得更加美好。

"你做到了，第 9 代收集者，"神秘的声音充满了喜悦，"你不仅修复了主宇宙，还让它变得更加丰富多彩。多元宇宙因为你而完整。"

你成为了传说中的概念之神，永远被铭记在多元宇宙的历史中。

【游戏完成】100%
【解锁成就】完美结局
【解锁成就】概念之神
【解锁成就】全宇宙探索者`,
                onEnter: () => {
                    gameData.achievements.push('ending_100');
                    gameData.achievements.push('collector_100');
                    gameData.achievements.push('all_universes');
                },
                choices: [
                    { text: "🎮 再次游戏", next: "start" },
                    { text: "📦 查看完整图鉴", next: "show_concepts_menu" }
                ]
            }
        };
        
        // ============ 音乐切换函数 ============
        function switchMusic(trackIndex) {
            if (!isMusicPlaying) return;
            if (trackIndex !== currentTrackIndex) {
                loadTrack(trackIndex);
            }
        }
        
        // ============ 存档系统函数 ============
        function toggleSaveSystem() {
            const saveSystem = document.getElementById('save-system');
            const gallery = document.getElementById('concept-gallery');
            const achievementSystem = document.getElementById('achievement-system');
            
            // 如果已经打开，则关闭
            if (!saveSystem.classList.contains('hidden')) {
                saveSystem.classList.add('hidden');
                return;
            }
            
            playSound('save');
            // 关闭其他面板，打开存档系统
            gallery.classList.add('hidden');
            achievementSystem.classList.add('hidden');
            saveSystem.classList.remove('hidden');
        }
        
        function selectSlot(slot) {
            selectedSlot = slot;
            document.querySelectorAll('.save-slot').forEach(s => s.style.borderColor = 'rgba(102, 126, 234, 0.3)');
            document.getElementById(`slot-${slot}`).style.borderColor = '#667eea';
            updateSlotInfo();
        }
        
        function updateSlotInfo() {
            for (let i = 1; i <= 3; i++) {
                const saved = localStorage.getItem(SAVE_PREFIX + i);
                const info = document.getElementById(`slot-${i}-info`);
                if (saved) {
                    const data = JSON.parse(saved);
                    info.textContent = `${data.currentUniverse} | ${data.concepts.length}概念 | ${data.score}分`;
                    document.getElementById(`slot-${i}`).classList.add('has-data');
                } else {
                    info.textContent = '空';
                    document.getElementById(`slot-${i}`).classList.remove('has-data');
                }
            }
        }
        
        function saveGame() {
            gameData.timestamp = Date.now();
            gameData.currentScene = getCurrentScene();
            gameData.universesVisited = Array.from(gameData.universesVisited);
            localStorage.setItem(SAVE_PREFIX + selectedSlot, JSON.stringify(gameData));
            playSound('save');
            showMessage('存档成功！', 'success');
            updateSlotInfo();
        }
        
        function loadGame() {
            const saved = localStorage.getItem(SAVE_PREFIX + selectedSlot);
            if (!saved) {
                showMessage('该存档位为空！', 'error');
                return;
            }
            const data = JSON.parse(saved);
            Object.assign(gameData, data);
            gameData.universesVisited = new Set(data.universesVisited || []);
            renderScene(gameData.currentScene || "start");
            playSound('save');
            showMessage('读档成功！', 'success');
            toggleSaveSystem();
        }
        
        function deleteSave() {
            if (confirm('确定要删除这个存档吗？')) {
                localStorage.removeItem(SAVE_PREFIX + selectedSlot);
                showMessage('存档已删除！', 'success');
                updateSlotInfo();
            }
        }
        
        function showMessage(msg, type) {
            const el = document.getElementById('save-message');
            el.textContent = msg;
            el.className = 'save-message ' + (type === 'success' ? 'save-success' : 'save-error');
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 2000);
        }
        
        function getCurrentScene() {
            return gameData.currentScene;
        }
        
        // ============ 概念图鉴函数 ============
        function toggleConcepts() {
            const gallery = document.getElementById('concept-gallery');
            const saveSystem = document.getElementById('save-system');
            const achievementSystem = document.getElementById('achievement-system');
            
            // 如果已经打开，则关闭
            if (!gallery.classList.contains('hidden')) {
                gallery.classList.add('hidden');
                return;
            }
            
            // 关闭其他面板，打开概念图鉴
            saveSystem.classList.add('hidden');
            achievementSystem.classList.add('hidden');
            gallery.classList.remove('hidden');
            
            const total = Object.keys(conceptDatabase).length;
            const collected = gameData.concepts.length;
            document.getElementById('concept-progress').textContent = `${collected}/${total}`;
            document.getElementById('concept-progress-bar').style.width = `${(collected/total)*100}%`;
            
            const list = document.getElementById('concept-list');
            list.innerHTML = '';
            
            for (const [id, concept] of Object.entries(conceptDatabase)) {
                const isCollected = gameData.concepts.includes(concept.name);
                const card = document.createElement('div');
                card.className = `concept-card ${concept.rarity.toLowerCase()} ${isCollected ? '' : 'locked-concept'}`;
                card.innerHTML = `
                    <div class="concept-card-header">
                        <span class="concept-card-title">${isCollected ? concept.name : '🔒 未收集'}</span>
                        <span class="rarity-badge ${concept.rarity.toLowerCase()}">${concept.rarity}</span>
                    </div>
                    <div class="concept-card-body">
                        ${isCollected ? `
                            <div><strong>类别:</strong> ${concept.category}</div>
                            <div><strong>描述:</strong> ${concept.description}</div>
                            <div class="concept-card-science"><strong>科学原理:</strong> ${concept.science}</div>
                        ` : '<div style="color: #666;">探索宇宙以解锁此概念</div>'}
                    </div>
                `;
                list.appendChild(card);
            }
        }
        
        // ============ 成就系统函数 ============
        function toggleAchievements() {
            const system = document.getElementById('achievement-system');
            const saveSystem = document.getElementById('save-system');
            const gallery = document.getElementById('concept-gallery');
            
            // 如果已经打开，则关闭
            if (!system.classList.contains('hidden')) {
                system.classList.add('hidden');
                return;
            }
            
            // 关闭其他面板，打开成就系统
            saveSystem.classList.add('hidden');
            gallery.classList.add('hidden');
            system.classList.remove('hidden');
            
            const list = document.getElementById('achievement-list');
            list.innerHTML = '';
            list.style.display = 'grid';
            list.style.gridTemplateColumns = 'repeat(auto-fit, minmax(200px, 1fr))';
            list.style.gap = '15px';
            
            for (const ach of achievements) {
                const isUnlocked = gameData.achievements.includes(ach.id);
                const card = document.createElement('div');
                card.className = `achievement-card ${isUnlocked ? 'unlocked' : 'locked'}`;
                card.innerHTML = `
                    <div class="achievement-icon">${ach.icon}</div>
                    <div class="achievement-name">${ach.name}</div>
                    <div class="achievement-desc">${ach.desc}</div>
                    ${isUnlocked ? '<div style="color: #43e97b; margin-top: 5px;">✓ 已解锁</div>' : '<div style="color: #666; margin-top: 5px;">🔒 未解锁</div>'}
                `;
                list.appendChild(card);
            }
        }
        
        // ============ 游戏核心函数 ============
        // 解锁成就辅助函数
        function unlockAchievement(achievementId) {
            if (!gameData.achievements.includes(achievementId)) {
                gameData.achievements.push(achievementId);
                const ach = achievements.find(a => a.id === achievementId);
                if (ach) {
                    playSound('achievement');
                    showAchievementNotification(ach);
                }
            }
        }
        
        function checkAchievements() {
            const newAchievements = [];
            
            if (gameData.concepts.length >= 1 && !gameData.achievements.includes('first_concept')) {
                newAchievements.push('first_concept');
            }
            if (gameData.concepts.length >= 10 && !gameData.achievements.includes('collector_10')) {
                newAchievements.push('collector_10');
            }
            if (gameData.concepts.length >= 30 && !gameData.achievements.includes('collector_30')) {
                newAchievements.push('collector_30');
            }
            if (gameData.concepts.length >= 50 && !gameData.achievements.includes('collector_50')) {
                newAchievements.push('collector_50');
            }
            if (gameData.concepts.length >= 80 && !gameData.achievements.includes('collector_80')) {
                newAchievements.push('collector_80');
            }
            if (gameData.concepts.length >= 100 && !gameData.achievements.includes('collector_100')) {
                newAchievements.push('collector_100');
            }
            if (gameData.universesVisited.size >= 5 && !gameData.achievements.includes('all_universes')) {
                newAchievements.push('all_universes');
            }
            if (gameData.universesVisited.size >= 1 && !gameData.achievements.includes('universe_jumper')) {
                newAchievements.push('universe_jumper');
            }
            if (gameData.score >= 500 && !gameData.achievements.includes('score_500')) {
                newAchievements.push('score_500');
            }
            if (gameData.score >= 1000 && !gameData.achievements.includes('score_1000')) {
                newAchievements.push('score_1000');
            }
            if (gameData.score >= 2000 && !gameData.achievements.includes('score_2000')) {
                newAchievements.push('score_2000');
            }
            if (gameData.choicesMade >= 100 && !gameData.achievements.includes('decision_maker')) {
                newAchievements.push('decision_maker');
            }
            
            if (newAchievements.length > 0) {
                gameData.achievements.push(...newAchievements);
                for (const achId of newAchievements) {
                    const ach = achievements.find(a => a.id === achId);
                    if (ach) showAchievementNotification(ach);
                }
            }
        }
        
        function showAchievementNotification(achievement) {
            // 播放音效
            playSound('achievement');
            
            // 屏幕中央粒子特效
            const centerX = window.innerWidth / 2;
            const centerY = window.innerHeight / 2;
            spawnParticles(centerX, centerY, 80, '#f0a500', 'sparkle');
            spawnParticles(centerX, centerY, 50, '#ffd700', 'sparkle');
            
            // 成就通知
            const notification = document.createElement('div');
            notification.className = 'concept-collected fade-in';
            notification.style.background = 'linear-gradient(135deg, rgba(240, 165, 0, 0.3), rgba(255, 196, 0, 0.3))';
            notification.style.borderColor = 'rgba(240, 165, 0, 0.6)';
            notification.style.boxShadow = '0 0 30px rgba(240, 165, 0, 0.6)';
            notification.innerHTML = `
                <div style="display: flex; align-items: center; gap: 10px; justify-content: center;">
                    <span>🏆</span>
                    <span>成就解锁！</span>
                </div>
                <div class="concept-name" style="color: #f0a500; text-shadow: 0 0 10px #f0a500;">${achievement.name}</div>
                <div style="font-size: 0.9em; color: #ccc;">${achievement.desc}</div>
            `;
            const container = document.getElementById('game-container');
            container.insertBefore(notification, container.firstChild);
            setTimeout(() => {
                notification.style.opacity = '0';
                notification.style.transition = 'opacity 0.5s ease';
                setTimeout(() => notification.remove(), 500);
            }, 4000);
        }
        
        function checkEnding() {
            const collected = gameData.concepts.length;
            const total = Object.keys(conceptDatabase).length;
            const percentage = (collected / total) * 100;
            
            if (percentage >= 100) {
                setTimeout(() => navigateTo("ending_100"), 1000);
            } else if (percentage >= 80) {
                setTimeout(() => navigateTo("ending_80"), 1000);
            } else if (percentage >= 50) {
                setTimeout(() => navigateTo("ending_50"), 1000);
            }
        }
        
        function resetGame() {
            if (confirm('确定要重新开始游戏吗？当前进度将丢失（除非已保存）！')) {
                gameData.concepts = [];
                gameData.currentUniverse = "主宇宙";
                gameData.chapter = 1;
                gameData.score = 0;
                gameData.choicesMade = 0;
                gameData.achievements = [];
                gameData.playTime = 0;
                gameData.universesVisited = new Set();
                renderScene("start");
                updateStatus();
            }
        }
        
        function collectConcept(conceptName) {
            if (!gameData.concepts.includes(conceptName)) {
                gameData.concepts.push(conceptName);
                // 按稀有度加分
                const concept = Object.values(conceptDatabase).find(c => c.name === conceptName);
                const score = concept ? (rarityScores[concept.rarity] || 10) : 10;
                gameData.score += score;
                playSound('collect');
                showConceptNotification(conceptName, concept ? concept.rarity : null);
                checkAchievements();
                checkEnding();
            }
        }
        
        function showConceptNotification(conceptName, rarity) {
            const notification = document.createElement('div');
            notification.className = 'concept-collected fade-in';
            const rarityText = rarity ? `【${rarity}】+${rarityScores[rarity] || 10}分` : '';
            notification.innerHTML = `
                <div>🎉 获得新概念！</div>
                <div class="concept-name">${conceptName}</div>
                <div style="font-size: 0.9em; color: #ccc; margin-top: 5px;">${rarityText}</div>
            `;
            const container = document.getElementById('game-container');
            container.insertBefore(notification, container.firstChild);
            setTimeout(() => notification.remove(), 3000);
        }
        
        function updateStatus() {
            document.getElementById('universe-display').textContent = gameData.currentUniverse;
            document.getElementById('concepts-display').textContent = gameData.concepts.length;
            document.getElementById('score-display').textContent = gameData.score;
            document.getElementById('chapter-display').textContent = gameData.chapter;
        }
        
        function renderScene(sceneId) {
            const scene = scenes[sceneId];
            if (!scene) {
                console.error(`Scene '${sceneId}' not found`);
                return;
            }
            
            if (scene.onEnter) scene.onEnter();
            
            const container = document.getElementById('game-container');
            let text = typeof scene.text === 'function' ? scene.text() : scene.text;
            text = text.replace(/\${gameData\.concepts\.length}/g, gameData.concepts.length);
            
            container.innerHTML = `
                <div class="scene fade-in ${sceneId.startsWith('ending') ? 'ending-scene' : ''}">
                    <h2 class="scene-title ${sceneId.startsWith('ending') ? 'ending-title' : ''}">${scene.title}</h2>
                    <div class="scene-text ${sceneId.startsWith('ending') ? 'ending-text' : ''}">${text.replace(/\n/g, '<br>')}</div>
                    <div class="choices">
                        ${scene.choices.map((choice, index) => {
                            const conceptParam = choice.concept ? `, '${choice.concept}'` : '';
                            return `
                            <button class="choice-btn" onclick="navigateTo('${choice.next}'${conceptParam})">
                                ${choice.text}
                            </button>
                        `;
                        }).join('')}
                    </div>
                </div>
            `;
            
            updateStatus();
            updateReturnButton();
            
            // 滚动到内容区顶部，而不是页面顶部
            const sceneElement = container.querySelector('.scene');
            if (sceneElement) {
                sceneElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
        
        // 返回主宇宙功能
        function returnToHome() {
            playSound('sceneChange');
            renderScene('start');
        }
        
        // 更新返回按钮显示状态
        function updateReturnButton() {
            const returnBtn = document.getElementById('return-home-btn');
            if (returnBtn) {
                if (gameData.currentScene === 'start') {
                    returnBtn.classList.add('hidden');
                } else {
                    returnBtn.classList.remove('hidden');
                }
            }
        }
        
        function navigateTo(sceneId, conceptName) {
            gameData.choicesMade++;
            gameData.currentScene = sceneId;
            
            // 收集概念（如果选择支有 concept 属性）
            if (conceptName) {
                collectConcept(conceptName);
            }
            
            if (sceneId.startsWith('space_')) gameData.currentUniverse = "太空歌剧宇宙";
            else if (sceneId.startsWith('time_')) gameData.currentUniverse = "时间旅行宇宙";
            else if (sceneId.startsWith('cyber_')) gameData.currentUniverse = "赛博朋克宇宙";
            else if (sceneId.startsWith('bio_')) gameData.currentUniverse = "生物朋克宇宙";
            else if (sceneId.startsWith('magic_')) gameData.currentUniverse = "魔法科技宇宙";
            else if (sceneId === 'start') gameData.currentUniverse = "主宇宙";
            
            renderScene(sceneId);
            checkAchievements();
        }
        
        // ============ 游戏初始化 ============
        window.addEventListener('DOMContentLoaded', () => {
            // 初始化音频系统
            initAudio();
            
            let hasSaves = false;
            for (let i = 1; i <= 3; i++) {
                if (localStorage.getItem(SAVE_PREFIX + i)) {
                    hasSaves = true;
                    break;
                }
            }
            
            if (hasSaves) {
                const container = document.getElementById('game-container');
                container.innerHTML = `
                    <div class="scene fade-in">
                        <h2 class="scene-title">🎮 欢迎回来，收集者！</h2>
                        <div class="scene-text">
                            检测到你有保存的游戏进度。
                            <br><br>
                            你可以：
                        </div>
                        <div class="choices">
                            <button class="choice-btn" onclick="toggleSaveSystem(); selectSlot(1); loadGame()">
                                📂 读取存档
                            </button>
                            <button class="choice-btn" onclick="renderScene('start'); resetGameData()">
                                🔄 开始新游戏
                            </button>
                            <button class="choice-btn" onclick="showConcepts()">
                                📦 查看概念图鉴
                            </button>
                            <button class="choice-btn" onclick="showAchievements()">
                                🏆 查看成就
                            </button>
                        </div>
                    </div>
                `;
            } else {
                renderScene("start");
            }
            
            updateStatus();
            selectSlot(1);
        });
        
        function resetGameData() {
            gameData.concepts = [];
            gameData.currentUniverse = "主宇宙";
            gameData.chapter = 1;
            gameData.score = 0;
            gameData.choicesMade = 0;
            gameData.achievements = [];
            gameData.playTime = 0;
            gameData.universesVisited = new Set();
            updateStatus();
        }
    </script>
</body>
</html>
